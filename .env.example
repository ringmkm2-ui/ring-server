# Ring Server - 環境変数テンプレート
# 本番環境では Render のダッシュボードで以下を設定してください

# (開発時のみ必要。本番は Render が自動で HTTPS にする)
PORT=3000

# JWT署名用秘密鍵 (本番では安全なランダム文字列に変更！)
JWT_SECRET=change-me-in-production-to-secure-random-string

# PostgreSQL接続情報 (本番でのみ使用。Supabaseを推奨)
# 開発はSQLiteを使用しているため不要
DATABASE_URL=postgresql://user:password@host:5432/ring_db
